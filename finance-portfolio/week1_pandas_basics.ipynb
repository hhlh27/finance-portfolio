   "source": [
    "# Get just the closing price\n",
    "close = spy[\"Close\"]\n",
    "\n",
    "# Basic stats\n",
    "print(close.describe())\n",
    "\n",
    "# Compute daily % returns\n",
    "returns = close.pct_change().dropna()#pct_change() computes (today - yesterday) / yesterday. This is the foundation of almost all quant work.\n",
    "print(\"\\nAvg daily return\", round(returns.mean() * 100,4),\"%\")\n",
    "print(\"Daily volatility:\", round(returns.std() * 100, 4), \"%\")"
   ]
